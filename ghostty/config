# Font
font-family = JetBrainsMono Nerd Font
font-family-bold = JetBrainsMono Nerd Font Bold
font-family-italic = JetBrainsMono Nerd Font Italic
font-family-bold-italic = JetBrainsMono Nerd Font Bold Italic
font-size = 13
font-thicken = true
font-feature = calt
font-feature = liga
bold-is-bright = true

# Cursor (block with smart color, matches iTerm2)
cursor-style = block
cursor-style-blink = true
cursor-color = #C678DE
cursor-text = #ABB2BF
cursor-invert-fg-bg = true
cursor-click-to-move = true

# Window
window-padding-x = 12
window-padding-y = 4
window-padding-balance = true
window-padding-color = extend
window-decoration = true
window-height = 25
window-width = 100
window-theme = dark
macos-titlebar-style = tabs
confirm-close-surface = false
window-inherit-font-size = true
window-step-resize = true
resize-overlay = after-first

# Splits
unfocused-split-opacity = 0.715
focus-follows-mouse = true

# Performance
window-vsync = true

# Scrollback
scrollback-limit = 10000

# Mouse
mouse-hide-while-typing = true
mouse-scroll-multiplier = 3

# Option key sends normal characters (not Esc+)
macos-option-as-alt = false

# Clipboard
copy-on-select = clipboard
clipboard-paste-protection = true

# Shell integration
shell-integration = zsh

# Key bindings
# Shift+Enter sends literal newline (matches iTerm2 mapping)
keybind = shift+enter=text:\n
# Option+Left/Right for word navigation
keybind = alt+left=esc:b
keybind = alt+right=esc:f
# Cmd+Delete kills line, Option+Delete kills word
keybind = super+backspace=text:\x15
keybind = alt+backspace=text:\x17

# ── One Dark color scheme (matched from iTerm2) ──────────────
background = #031B21
foreground = #C0C3CB
selection-background = #323844
selection-foreground = #ABB2BF

# Normal colors
palette = 0=#21252B
palette = 1=#C98389
palette = 2=#9AB488
palette = 3=#E5C07B
palette = 4=#7DACD3
palette = 5=#BB8CC9
palette = 6=#56B6C2
palette = 7=#ABB2BF

# Bright colors
palette = 8=#767676
palette = 9=#C98389
palette = 10=#9AB488
palette = 11=#E5C07B
palette = 12=#7DACD3
palette = 13=#BB8CC9
palette = 14=#56B6C2
palette = 15=#ABB2BF
