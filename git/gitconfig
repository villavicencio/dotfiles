[user]
    name = David Villavicencio
    email = villavicencio.david@gmail.com
[push]
    default = current
    recurseSubmodules = on-demand
[commit]
    #template = ~/.gitcommit.template
[color]
    ui = true
    status = true
    branch = true
    interactive = true
    diff = true
[core]
    editor = vim
    ignorecase = false
    excludesfile = ~/.config/git/gitignore
    attributesfile = ~/.config/git/gitattributes
    pager = vim -
[help]
    autocorrect = 1
[diff]
	submodule = log
[status]
	submoduleSummary = true
[fetch]
	recurseSubmodules = on-demand
[merge]
    ff = only
    conflictStyle = zdiff3
[credential]
	helper = osxkeychain
	helper = 
	helper = /usr/local/share/gcm-core/git-credential-manager
[pager]
    diff = delta
    show = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    line-numbers = true
[alias]
	# Basic aliases
	stat = status
    co = checkout
    ci = commit

    # View abbreviated SHA, description, and history graph of the latest commits
    ls = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cgreen\\ [%cn]" --decorate --date=short
    ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cgreen\\ [%cn]" --decorate --numstat

    # Find commits by commit message
    fm = "!f() { git log --pretty=format:'%C(yellow)%h  %Cblue%ad  %Creset%s%Cgreen  [%cn] %Cred%d' --decorate --date=short --grep=$1; }; f"

    # List contributors with number of commits
    contributors = shortlog --summary --numbered
[submodule]
    fetchJobs = 4
[pull]
	rebase = false
[init]
	defaultBranch = main
[credential "https://huggingface.co"]
	provider = generic
[credential "https://github.com"]
	helper = 
	# Absolute path (not bare `gh`): git credential helpers are invoked by GUI/IDE
	# git clients with a minimal PATH that never sourced the shell, where bare `gh`
	# fails with "command not found" and the scoped block has no fallback. Both
	# machines are Apple Silicon, so /opt/homebrew/bin/gh is correct on both; git
	# config has no $BREW_PREFIX expansion, so an absolute literal is the only
	# PATH-independent option.
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

# Machine-specific overrides (git identity, work email, etc.)
# On a work machine, create ~/.gitconfig.local with:
#   [user]
#       email = <your-work-email>
[include]
    path = ~/.gitconfig.local
[credential "https://dev.azure.com"]
	useHttpPath = true
